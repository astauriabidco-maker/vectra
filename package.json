    "nx": "turbo"
  },
  "devDependencies": {
    "turbo": "latest"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "optionalDependencies": {
    "@next/swc-linux-x64-gnu": "^16.1.2"
  }
}